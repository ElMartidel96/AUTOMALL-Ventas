# ---------------------------------------------------------------------------
# App Identity
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Autos MALL
NEXT_PUBLIC_APP_DOMAIN=autosmall.com
NEXT_PUBLIC_BRAND_MODE=automall

# ---------------------------------------------------------------------------
# Feature Flags (AutosMall defaults: Web3 hidden, social login only)
